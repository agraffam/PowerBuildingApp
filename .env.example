# Copy to .env and fill in. Never commit .env (see .gitignore).

# SQLite (local dev). Docker Compose sets its own DATABASE_URL inside the container.
DATABASE_URL="file:./prisma/dev.db"

# Required in production. Min 16 characters.
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional: LAN dev with Next.js / CSRF (see docs/DEVELOPMENT.md)
# ALLOWED_DEV_ORIGINS=192.168.1.10

# Optional: force cookie Secure flag behind proxies
# SESSION_COOKIE_SECURE=false

# Optional: session cookie max-age in seconds (default 30 days). Clamped 300–7776000.
# SESSION_MAX_AGE_SEC=1209600

# Optional: auth rate limits (in-memory; single instance). Disabled for Playwright via AUTH_RATE_LIMIT_DISABLED.
# AUTH_RATE_LIMIT_LOGIN_MAX=30
# AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=900000
# AUTH_RATE_LIMIT_REGISTER_MAX=10
# AUTH_RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# AUTH_RATE_LIMIT_DISABLED=0
