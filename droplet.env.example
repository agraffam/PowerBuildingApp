# Copy to .env on your droplet (same directory as docker-compose.droplet.yml).
# Do not commit .env.

# Required: long random string (Compose also accepts export AUTH_SECRET=... in shell)
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Prebuilt image from GitHub Container Registry (see GitHub → Packages after CI runs)
# Example: ghcr.io/agraffam/powerbuildingapp:latest
PB_IMAGE=ghcr.io/YOUR_GITHUB_USER/YOUR_REPO_LOWERCASE:latest

# Optional: host port (default 3500)
# HOST_PORT=443

# Optional: first boot seed (0 = normal; 1 = force full seed — avoid on real data)
# START_SEED=0
