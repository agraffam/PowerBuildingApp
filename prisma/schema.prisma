generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BlockType {
  HYPERTROPHY
  STRENGTH
  PEAKING
}

/** Slot classification for block-based prescription scaling (optional on each ProgramExercise). */
enum PrescriptionLoadRole {
  COMPOUND
  ACCESSORY
  ISOLATION
  CARDIO
}

enum SessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WeightUnit {
  KG
  LB
}

enum ProgramInstanceStatus {
  ACTIVE
  /** Switched away mid-cycle; progress preserved for resume. */
  PAUSED
  COMPLETED
  /** User ended run or superseded; hidden from resume list. */
  ARCHIVED
}

enum ExerciseKind {
  STRENGTH
  CARDIO
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  passwordHash       String
  name               String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  settings           UserSettings?
  ownedPrograms      Program[]             @relation("OwnedPrograms")
  programInstances   ProgramInstance[]
  strengthProfiles   UserStrengthProfile[]
  exerciseLiftPrefs  UserExerciseLift[]
}

model UserSettings {
  id                   String     @id @default(cuid())
  userId               String     @unique
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredWeightUnit  WeightUnit @default(LB)
  defaultRestSec       Int        @default(180)
  plateIncrementLb     Float      @default(2.5)
  plateIncrementKg     Float      @default(2.5)
  keepAwakeDuringWorkout Boolean  @default(false)
  /** Optional overrides: { "6": sec, … "10": sec } — merged with built-in ladder (30–210s steps). */
  restDurationsByRpe   Json?
  updatedAt            DateTime   @updatedAt
}

model Exercise {
  id                 String                @id @default(cuid())
  name               String
  slug               String                @unique
  muscleTags         String                @default("") // comma-separated
  notes              String?
  kind               ExerciseKind          @default(STRENGTH)
  /** Library default: log sets as bodyweight (weight stored as 0). */
  isBodyweight       Boolean               @default(false)
  /** Library default bar step (lb). Per-user override in UserExerciseLift. */
  barIncrementLb     Float?
  createdAt          DateTime              @default(now())
  programUses        ProgramExercise[]
  userStrengthProfiles UserStrengthProfile[]
  userLiftPrefs      UserExerciseLift[]
  instanceReplacementPicks ProgramInstanceExerciseReplacement[] @relation("InstanceReplacementExercise")
  sessionSwapPicks         WorkoutSessionExerciseSwap[]         @relation("SessionSwapExercise")
  loggedSetOverrides       LoggedSet[]                          @relation("LoggedSetExerciseOverride")
}

model UserStrengthProfile {
  id             String     @id @default(cuid())
  userId         String
  exerciseId     String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise       Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  estimatedOneRm Float
  weightUnit     WeightUnit
  updatedAt      DateTime   @updatedAt

  @@unique([userId, exerciseId])
  @@index([exerciseId])
}

/** Per-user bar increment override for an exercise (replaces PATCH on Exercise.barIncrementLb). */
model UserExerciseLift {
  id              String   @id @default(cuid())
  userId          String
  exerciseId      String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise        Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  barIncrementLb  Float?

  @@unique([userId, exerciseId])
}

model Program {
  id             String            @id @default(cuid())
  /** Stable id for seeded system templates; null for user-created programs. */
  seedKey        String?           @unique
  name           String
  durationWeeks  Int
  /** Every N calendar weeks (4–6) apply a deload; null = off. */
  deloadIntervalWeeks Int?
  /** When false, use stored ProgramExercise targets only (legacy). */
  autoBlockPrescriptions Boolean @default(true)
  createdAt      DateTime          @default(now())
  ownerId        String?
  owner          User?             @relation("OwnedPrograms", fields: [ownerId], references: [id], onDelete: SetNull)
  blocks         ProgramBlock[]
  days           ProgramDay[]
  instances      ProgramInstance[]

  @@index([ownerId])
}

model ProgramBlock {
  id        String    @id @default(cuid())
  programId String
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  blockType BlockType
  sortOrder Int
  startWeek Int
  endWeek   Int
}

model ProgramDay {
  id         String            @id @default(cuid())
  programId  String
  program    Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  sortOrder  Int
  label      String
  exercises  ProgramExercise[]
  sessions   WorkoutSession[]
  skippedByInstances ProgramInstanceSkippedDay[]
}

model ProgramExercise {
  id              String      @id @default(cuid())
  programDayId    String
  programDay      ProgramDay  @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sortOrder       Int
  /** Same non-null value on consecutive exercises = superset (interleaved in workout UI). */
  supersetGroup   String?
  sets            Int
  /** Strength: required for auto prescriptions. Cardio: may be null (use bouts + duration). */
  repTarget       Int?
  targetRpe       Float?
  /** How to scale reps/RPE/% through mesocycle blocks; null = infer from exercise + repTarget. */
  loadRole        PrescriptionLoadRole?
  pctOf1rm        Float?
  restSec         Int?
  /** null = follow Exercise.isBodyweight; true/false overrides for this slot. */
  useBodyweight   Boolean?
  notes           String?
  /** Cardio: target time per bout (e.g. interval length). Strength: optional. */
  targetDurationSec Int?
  targetCalories  Int?
  loggedSets      LoggedSet[]
  instanceReplacements ProgramInstanceExerciseReplacement[]
  sessionExerciseSwaps WorkoutSessionExerciseSwap[]
  instanceBodyweightOverrides ProgramInstanceExerciseBodyweight[]
  sessionBodyweightOverrides  WorkoutSessionExerciseBodyweight[]
}

model ProgramInstance {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId        String
  program          Program                 @relation(fields: [programId], references: [id], onDelete: Cascade)
  status           ProgramInstanceStatus   @default(ACTIVE)
  weekIndex        Int                     @default(0)
  nextDaySortOrder Int                     @default(0)
  startedAt        DateTime                @default(now())
  /** { [programDayId]: programExerciseId[] } — order for Train preview / next session for that day. */
  plannedExerciseOrderByDay Json?
  sessions         WorkoutSession[]
  exerciseReplacements ProgramInstanceExerciseReplacement[]
  exerciseBodyweightOverrides ProgramInstanceExerciseBodyweight[]
  skippedDays      ProgramInstanceSkippedDay[]

  @@index([userId])
}

/** Training day marked skipped for a given program week (no workout started/completed). */
model ProgramInstanceSkippedDay {
  id                  String          @id @default(cuid())
  programInstanceId   String
  programInstance     ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  weekIndex           Int
  programDayId        String
  programDay          ProgramDay      @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  createdAt           DateTime        @default(now())

  @@unique([programInstanceId, weekIndex, programDayId])
  @@index([programInstanceId, weekIndex])
}

/** Per user instance: replace template exercise in a slot for all future sessions (and current when applied). */
model ProgramInstanceExerciseReplacement {
  id                    String          @id @default(cuid())
  programInstanceId     String
  programInstance       ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  programExerciseId     String
  programExercise       ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  replacementExerciseId String
  replacementExercise   Exercise        @relation("InstanceReplacementExercise", fields: [replacementExerciseId], references: [id], onDelete: Cascade)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([programInstanceId, programExerciseId])
  @@index([programExerciseId])
}

/** Per-instance bodyweight mode for a template slot (system templates where ProgramExercise cannot be edited). */
model ProgramInstanceExerciseBodyweight {
  id                  String          @id @default(cuid())
  programInstanceId   String
  programInstance     ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  programExerciseId   String
  programExercise     ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  useBodyweight       Boolean
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([programInstanceId, programExerciseId])
  @@index([programExerciseId])
}

/** Override template exercise for one workout session only (takes precedence over instance replacement). */
model WorkoutSessionExerciseSwap {
  id                    String         @id @default(cuid())
  workoutSessionId      String
  workoutSession        WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  programExerciseId     String
  programExercise       ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  replacementExerciseId String
  replacementExercise   Exercise       @relation("SessionSwapExercise", fields: [replacementExerciseId], references: [id], onDelete: Cascade)
  createdAt             DateTime       @default(now())

  @@unique([workoutSessionId, programExerciseId])
  @@index([programExerciseId])
}

model WorkoutSession {
  id                  String           @id @default(cuid())
  programInstanceId   String
  programInstance     ProgramInstance  @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  programDayId        String
  programDay          ProgramDay       @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  weekIndex           Int
  performedAt         DateTime         @default(now())
  status              SessionStatus    @default(PLANNED)
  sleep               Int?
  stress              Int?
  soreness            Int?
  intensityMultiplier Float            @default(1)
  /** First time user submitted readiness for this session (workout clock start). */
  workoutStartedAt    DateTime?
  /** Set when session is marked completed. */
  workoutCompletedAt  DateTime?
  /** Permutation of programExercise ids for this day; null = template sortOrder. */
  exerciseOrder       Json?
  readinessEntry      ReadinessEntry?
  sets                LoggedSet[]
  exerciseSwaps       WorkoutSessionExerciseSwap[]
  exerciseBodyweightOverrides WorkoutSessionExerciseBodyweight[]
}

/** Session-only bodyweight override for a slot (precedence over instance + template). */
model WorkoutSessionExerciseBodyweight {
  id                  String         @id @default(cuid())
  workoutSessionId    String
  workoutSession      WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  programExerciseId   String
  programExercise     ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  useBodyweight       Boolean
  createdAt           DateTime       @default(now())

  @@unique([workoutSessionId, programExerciseId])
  @@index([programExerciseId])
}

model ReadinessEntry {
  id               String         @id @default(cuid())
  workoutSessionId String         @unique
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  sleep            Int
  stress           Int
  soreness         Int
  createdAt        DateTime       @default(now())
}

model LoggedSet {
  id                 String          @id @default(cuid())
  workoutSessionId   String
  workoutSession     WorkoutSession  @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  programExerciseId  String
  programExercise    ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  /** Lift being logged when user swapped the template exercise (null = use programExercise.exerciseId). */
  loggedExerciseId   String?
  loggedExercise     Exercise?       @relation("LoggedSetExerciseOverride", fields: [loggedExerciseId], references: [id], onDelete: SetNull)
  setIndex           Int
  weight             Float
  weightUnit         WeightUnit
  reps               Int?
  rpe                Float?
  /** Cardio: duration logged for this set/bout (seconds). */
  durationSec        Int?
  calories           Int?
  done               Boolean         @default(false)
  completedAt        DateTime?

  @@unique([workoutSessionId, programExerciseId, setIndex])
  @@index([programExerciseId])
  @@index([loggedExerciseId])
}
